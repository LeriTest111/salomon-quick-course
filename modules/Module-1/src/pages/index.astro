---
import "../styles/global.css";
import productBanner from "../images/product-banner.jpg?url";
import whoWeAreBanner from "../images/who-we-are-banner.avif?url";
import whoWeAreVideoOne from "../images/who-we-are-1.mp4?url";
import whiteLogo from "../images/White-logo.svg?url";

const salomonImages = import.meta.glob("../images/salomon/**/*.{png,jpg,jpeg,avif,svg}", {
  eager: true,
  query: "?url",
  import: "default",
});

const resolveSalomonImage = (path) =>
  path.startsWith("/salomon/")
    ? salomonImages[`../images/salomon/${path.slice("/salomon/".length)}`] ?? path
    : path;

const navItems = [
  { href: "#overview", label: "Overview" },
  { href: "#positioning", label: "Positioning" },
  { href: "#timeline", label: "Timeline" },
  { href: "#legends", label: "Tech legends" },
];

const moduleGuide = [
  {
    module: "Module 1",
    title: "Salomon Footwear History",
    detail: "Learn how Salomon footwear evolved and how the brand story supports confident selling.",
    image: "/salomon/hero-brand.png",
  },
  {
    module: "Module 2",
    title: "Trail Running Basics",
    detail: "Understand trail running and how terrain, distance, and product choice connect.",
    image: "/salomon/hero-icons.png",
  },
  {
    module: "Module 3",
    title: "Road Running Basics",
    detail: "Understand road running needs and how Salomon supports different running goals.",
    image: "/salomon/hero-road.png",
  },
  {
    module: "Module 4",
    title: "Gravel Running Explained",
    detail: "Understand the gravel range and when to use each model.",
    image: "/salomon/hero-gravel.png",
  },
];

const positioningPillars = [
  {
    title: "Premium",
    detail: "The shoes are built for performance and comfort, using quality materials that last longer and perform better in tough conditions. Customers are paying for reliability, comfort and confidence, not just a name.",
  },
  {
    title: "Innovative",
    detail: "This shoe creates solutions to real running and outdoor problems. This includes better grip on wet or uneven surfaces, more comfort over long distances, and a more secure fit.",
  },
  {
    title: "Authentic",
    detail: "This shoe comes from real mountain sport experience. The products are shaped by athletes, designers and engineers who test them in real outdoor environments, not just in a lab.",
  },
];

const timeline = [
  {
    year: "1992",
    title: "FIRST SALOMON HIKING BOOT",
    detail: "Salomon enters the outdoor game with its first hiking silhouette",
    image: "/salomon/history-first-hiking-boot.jpg",
  },
  {
    year: "1993",
    title: "QUICKLACE",
    image: "/salomon/history-quicklace.jpg",
  },
  {
    year: "1994",
    title: "CONTAGRIP",
    image: "/salomon/history-contagrip.jpg",
  },
  {
    year: "2002",
    title: "LAUNCH OF XA PRO",
    detail: "The XA PRO debuts, blending trail performance with durability",
    image: "/salomon/history-xa-pro.jpg",
  },
  {
    year: "2006",
    title: "LAUNCH OF SPEEDCROSS",
    detail: "The birth of a trail legend, built for grip and precision",
    image: "/salomon/history-speedcross.jpg",
  },
  {
    year: "2012",
    title: "LAUNCH OF X ULTRA",
    detail: "Fast hiking redefined with lightweight agility and stability",
    image: "/salomon/history-x-ultra.jpg",
  },
  {
    year: "2013",
    title: "LAUNCH OF XT-6",
    detail: "Designed for ultra-distance athletes now a fashion icon",
    image: "/salomon/history-xt-6.jpg",
  },
  {
    year: "2021",
    title: "SUSTAINABLE TECH INDEX 1.0",
    detail: "Salomon commits to planet-first product innovation",
    image: "/salomon/history-tech-index.jpg",
  },
  {
    year: "2024",
    title: "S/LAB ULTRA GLIDE",
    detail: "A new benchmark in comfort, fit, and downhill flow",
    image: "/salomon/history-ultra-glide.jpg",
  },
];

const dareSteps = [
  "Divide the team into two groups: customers and sales associates.",
  "Form two lines facing each other.",
  "Customers each hide a random object behind their back.",
  "Sales associates have up to 10 seconds to break the ice with one sentence based on that object.",
  "Walk forward, swap roles, and repeat.",
  "Debrief what felt easy to connect, what felt difficult, and what made the customer react.",
];

const sectionPadding = "px-6 pt-6 pb-10 md:px-8 md:pt-8 md:pb-12 lg:px-10 lg:pt-10 lg:pb-14";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Module 1 | Brand story, history, and tech legends</title>
  </head>
  <body class="selection:bg-[var(--sal-lime)] selection:text-black">
    <main class="sal-shell min-h-screen">
      <div class="sal-fixed-nav fixed inset-x-0 top-0 z-[90]">
        <header class="sal-section overflow-visible px-4 py-4 md:px-6 lg:px-[8vw]" style="z-index:90; isolation:isolate;">
          <div class="flex items-center justify-between gap-4 md:hidden">
            <div class="flex min-w-0 items-center gap-3">
              <img src="/tfg-logo.svg" alt="TFG logo" class="h-10 w-10 shrink-0" />
              <p class="sal-ui-text min-w-0 font-medium text-[var(--sal-ink-soft)]">Module 1 | Brand story, history, and tech legends</p>
            </div>

            <details class="relative z-[70] shrink-0 md:hidden" data-mobile-nav style="z-index:70;">
              <summary class="flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-full border border-[rgba(12,12,12,0.1)] bg-white text-[var(--sal-ink-soft)] transition hover:bg-[#f4efea] [&::-webkit-details-marker]:hidden">
                <span class="sr-only">Toggle lesson navigation</span>
                <span aria-hidden="true" class="flex flex-col gap-[0.28rem]">
                  <span class="block h-[2px] w-5 rounded-full bg-current"></span>
                  <span class="block h-[2px] w-5 rounded-full bg-current"></span>
                  <span class="block h-[2px] w-5 rounded-full bg-current"></span>
                </span>
              </summary>

              <div class="absolute right-0 top-[calc(100%+0.75rem)] z-[80] w-64 max-w-[calc(100vw-1.5rem)] overflow-hidden rounded-[0.9rem] border border-[rgba(12,12,12,0.08)] bg-white p-2 shadow-[0_14px_36px_rgba(56,39,27,0.09)]" style="z-index:80;">
                <div class="sal-ui-text flex flex-col gap-1.5 text-[var(--sal-ink-soft)]">
                  {navItems.map((item) => (
                    <a href={item.href} class="rounded-[0.75rem] px-4 py-3 transition hover:bg-[#f4efea]" data-mobile-nav-link>{item.label}</a>
                  ))}
                </div>
              </div>
            </details>
          </div>

          <div class="hidden md:flex md:items-center md:justify-between md:gap-6">
            <div class="flex min-w-0 items-center gap-4">
              <img src="/tfg-logo.svg" alt="TFG logo" class="h-11 w-11 shrink-0" />
              <div class="min-w-0">
                <p class="sal-body-copy font-semibold tracking-[-0.03em] text-[var(--sal-ink-soft)]">Module 1 | Brand story, history, and tech legends</p>
              </div>
            </div>

            <nav class="sal-ui-text flex gap-2 overflow-x-auto pb-1 font-bold uppercase tracking-[0.12em] text-[var(--sal-ink-soft)]">
              {navItems.map((item) => (
                <a href={item.href} class="sal-chip whitespace-nowrap hover:border-[rgba(12,12,12,0.22)] hover:bg-white">{item.label}</a>
              ))}
            </nav>
          </div>
        </header>
      </div>

      <div class="w-full pb-4 pt-24 md:pb-6 md:pt-28">
        <section
          class="sal-card-dark sal-section sal-hero-banner mt-5 overflow-hidden px-6 py-8 md:mt-6 md:px-10 md:py-12"
        >
          <div class="sal-hero-banner__media" aria-hidden="true">
            <img src={resolveSalomonImage("/salomon/hero-brand.png")} alt="" class="sal-hero-banner__image" />
          </div>
          <div class="grid gap-8 lg:grid-cols-[1.32fr_0.68fr] lg:items-end">
            <div class="sal-hero-stack">
              <div class="sal-hero-lockup">
                <img src={whiteLogo} alt="Salomon logo" class="sal-hero-logo" />
                <span class="sal-module-pill">Module 1</span>
              </div>

              <div class="sal-hero-heading">
                <span class="sal-hero-heading__intro">Welcome to</span>
                <h1 class="sal-title-hero sal-hero-heading__title text-white">
                  the Salomon Footwear Course
                </h1>
              </div>
              <p class="sal-body-copy text-white/78">
                This course will help you learn how to choose the right Salomon shoes for customers based on their needs and running conditions.
              </p>
            </div>
          </div>
        </section>

        <section id="overview" class="sal-card sal-section mt-6 scroll-mt-28 md:scroll-mt-32">
          <div class={sectionPadding}>
            <div>
              <div>
                <p class="sal-kicker text-[#6a6257]">In this course</p>
                <p class="sal-body-copy mt-5 max-w-[42rem] text-[#403b34]">
                  In this course, you will be introduced to the following modules.
                </p>
                <div class="mt-8 grid gap-4 xl:grid-cols-4 md:grid-cols-2">
                  {moduleGuide.map((item) => (
                    <article
                      class="sal-module-card"
                      style={`background-image:url(${resolveSalomonImage(item.image)}); background-size:cover; background-position:center;`}
                    >
                      <div class="sal-module-card__overlay">
                        <p class="sal-kicker text-white/72">{item.module}</p>
                        <h3 class="sal-title-product text-white">{item.title}</h3>
                      </div>
                    </article>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="sal-section mt-0 overflow-hidden">
          <div
            class="sal-photo-strip sal-course-banner"
            style="border:none; border-top-left-radius:0.5625rem; border-top-right-radius:0.5625rem; border-bottom-left-radius:0; border-bottom-right-radius:0;"
          >
            <img src={whoWeAreBanner} alt="Mountain landscape from Salomon brand imagery" />
          </div>
        </section>

        <section id="positioning" class="sal-card-dark sal-section mt-0 scroll-mt-28 md:scroll-mt-32">
          <div class={sectionPadding}>
            <div class="grid gap-8">
              <div>
                <p class="sal-kicker text-white/64">Brand positioning</p>
                <h2 class="sal-topo-divider sal-title-section mt-3 inline-block text-white">
                  Premium, innovative, authentic
                </h2>
                <div class="mt-6 rounded-[0.5625rem] border border-white/10 bg-white/6 p-6 text-white">
                  <p class="sal-kicker text-[var(--sal-lime)]">The line to remember</p>
                  <p class="sal-title-product mt-4 uppercase text-white">We are the most premium, innovative and authentic brand for the mountain sport lifestyle</p>
                </div>
              </div>

              <div class="grid gap-4 md:grid-cols-3">
                {positioningPillars.map((pillar, index) => (
                  <article
                    class="rounded-[0.5625rem] border border-white/10 p-5 shadow-[0_18px_36px_rgba(0,0,0,0.22)]"
                    style={`background:${index === 0 ? "rgba(255,255,255,0.08)" : index === 1 ? "rgba(255,255,255,0.06)" : "rgba(255,255,255,0.1)"};`}
                  >
                    <h3 class="sal-title-product text-white">{pillar.title}</h3>
                    <p class="sal-body-copy mt-3 text-white/78">{pillar.detail}</p>
                  </article>
                ))}
              </div>
            </div>
          </div>
        </section>

        <section id="timeline" class="sal-card sal-section mt-6 overflow-hidden scroll-mt-28 md:scroll-mt-32">
          <div>
            <div
              class="sal-history-hero"
              style="border-top-left-radius:0; border-top-right-radius:0; border-bottom-left-radius:0.5625rem; border-bottom-right-radius:0.5625rem;"
            >
              <video
                src={whoWeAreVideoOne}
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
                aria-label="Looping Salomon brand video showing movement in mountain terrain"
              ></video>
            </div>
          </div>

          <div class={`${sectionPadding} pt-7`}>
            <p class="sal-kicker text-[#6a6257]">Brand history</p>
            <h2 class="sal-topo-divider sal-title-section sal-title-section--history mt-3 text-[var(--sal-ink)]">
              Learn how Salomon footwear evolved to meet different running and outdoor needs
            </h2>
            <p class="sal-body-copy mt-5 max-w-none text-[#403b34]">
              Let's look at the brand history below.
            </p>

            <div class="sal-history-flow mt-8" aria-label="Salomon brand history timeline">
              {timeline.map((item, index) => (
                <article class={`sal-history-flow__item ${index % 2 === 0 ? "sal-history-flow__item--right" : "sal-history-flow__item--left"}`}>
                  <div class="sal-history-flow__node" aria-hidden="true"></div>
                  <div class="sal-history-slide__frame sal-history-slide__frame--compact">
                    {item.image && (
                      <div class="sal-history-slide__photo sal-history-slide__photo--compact">
                        <img src={resolveSalomonImage(item.image)} alt={`${item.title} Salomon product visual`} />
                      </div>
                    )}

                    <div class="sal-history-slide__content">
                      <div class="sal-history-slide__header">
                        <p class="sal-history-slide__year">{item.year}</p>
                        <p class="sal-history-slide__title">{item.title}</p>
                      </div>

                      <div class="sal-history-slide__copy sal-history-slide__copy--compact">
                        {item.detail ? (
                          <p class="sal-body-copy text-[#2f2b26]">{item.detail}</p>
                        ) : (
                          <p class="sal-body-copy text-[#2f2b26]">
                            A defining Salomon milestone that helped shape the brand story customers know today.
                          </p>
                        )}
                      </div>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section class="sal-section mt-0 overflow-hidden">
          <div
            class="sal-photo-strip sal-course-banner"
            style="border:none; border-top-left-radius:0.5625rem; border-top-right-radius:0.5625rem; border-bottom-left-radius:0; border-bottom-right-radius:0;"
          >
            <img src={productBanner} alt="Salomon product banner imagery" />
          </div>
        </section>

        <section id="legends" class="sal-card-dark sal-section mt-0 scroll-mt-28 md:scroll-mt-32">
          <div class={sectionPadding}>
            <p class="sal-kicker text-white/64">Salomon tech legends</p>
            <h2 class="sal-topo-divider sal-title-section mt-3 text-white">
              The glossary that helps the range make sense
            </h2>
            <div class="mt-8">
              <a href="/downloads/salomon-tech-legends-glossary.pdf" class="sal-glossary-cta__link" download>Download glossary PDF</a>
            </div>
          </div>
        </section>

      </div>
    </main>
    <script>
      const mobileNavs = document.querySelectorAll("[data-mobile-nav]");
      document.addEventListener("click", (event) => {
        mobileNavs.forEach((menu) => {
          if (!menu.contains(event.target)) {
            menu.removeAttribute("open");
          }
        });
      });

      mobileNavs.forEach((menu) => {
        menu.querySelectorAll("[data-mobile-nav-link]").forEach((link) => {
          link.addEventListener("click", () => {
            menu.removeAttribute("open");
          });
        });
      });
    </script>
  </body>
</html>
