---
import "../styles/global.css";
import productBanner from "../images/prod-banner.jpg?url";
import whoWeAreBanner from "../images/who we are banner.avif?url";
import whoWeAreVideoOne from "../images/who we are 1.mp4?url";

const salomonImages = import.meta.glob("../images/salomon/**/*.{png,jpg,jpeg,avif,svg}", {
  eager: true,
  query: "?url",
  import: "default",
});

const resolveSalomonImage = (path) =>
  path.startsWith("/salomon/")
    ? salomonImages[`../images/salomon/${path.slice("/salomon/".length)}`] ?? path
    : path;

const navItems = [
  { href: "#overview", label: "Overview" },
  { href: "#positioning", label: "Positioning" },
  { href: "#timeline", label: "Timeline" },
  { href: "#legends", label: "Tech legends" },
];

const moduleGuide = [
  {
    module: "Module 1",
    title: "Brand story, history, and tech legends",
    detail: "Start with the brand, the timeline, the key technology terms, and simple selling habits.",
    image: "/salomon/hero-brand.png",
  },
  {
    module: "Module 2",
    title: "Trail running",
    detail: "Learn the trail range, from easy-entry comfort to technical and speed-led shoes.",
    image: "/salomon/hero-icons.png",
  },
  {
    module: "Module 3",
    title: "Gravel running",
    detail: "Understand the two gravel options and when to use each one.",
    image: "/salomon/hero-gravel.png",
  },
  {
    module: "Module 4",
    title: "Road running",
    detail: "Learn the road comfort and speed shoes, plus the rest of the road range.",
    image: "/salomon/hero-road.png",
  },
];

const positioningPillars = [
  {
    title: "Premium",
    detail: "Salomon should feel like the premium choice: well made, trusted, and built for real mountain use.",
  },
  {
    title: "Innovative",
    detail: "Translate technology into a felt benefit: more bounce, more grip, more comfort, more protection, and a cleaner fit.",
  },
  {
    title: "Authentic",
    detail: "Salomon comes from mountain sport. The story feels believable because it was built in real terrain, not styled from a distance.",
  },
];

const timeline = [
  {
    year: "1992",
    title: "FIRST SALOMON HIKING BOOT",
    detail: "Salomon enters the outdoor game with its first hiking silhouette",
    image: "/salomon/history-first-hiking-boot.jpg",
  },
  {
    year: "1993",
    title: "quickLACE",
    image: "/salomon/history-quicklace.jpg",
  },
  {
    year: "1994",
    title: "contaGRIP",
    image: "/salomon/history-contagrip.jpg",
  },
  {
    year: "2002",
    title: "LAUNCH OF XA PRO",
    detail: "The xa pro debuts, blending trail performance with durability",
    image: "/salomon/history-xa-pro.jpg",
  },
  {
    year: "2006",
    title: "LAUNCH OF SPEEDCROSS",
    detail: "The birth of a trail legend, built for grip and precision",
    image: "/salomon/history-speedcross.jpg",
  },
  {
    year: "2012",
    title: "LAUNCH OF X ULTRA",
    detail: "Fast hiking redefined with lightweight agility and stability",
    image: "/salomon/history-x-ultra.jpg",
  },
  {
    year: "2013",
    title: "LAUNCH OFXT-6",
    detail: "Designed for ultra-distance athletes now a fashion icon",
    image: "/salomon/history-xt-6.jpg",
  },
  {
    year: "2021",
    title: "SUSTAINABLE TECH INDEX 1.0",
    detail: "Salomon commits to planet-first product innovation",
    image: "/salomon/history-tech-index.jpg",
  },
  {
    year: "2024",
    title: "S/LAB ULTRA GLIDE",
    detail: "A new benchmark in comfort, fit, and downhill flow",
    image: "/salomon/history-ultra-glide.jpg",
  },
];

const legendGroups = [
  {
    title: "Other",
    detail: "Brand, grip, and movement stories.",
    panel: "rgba(247,246,243,0.96)",
    border: "rgba(157,120,97,0.2)",
    accent: "#8f705d",
    items: [
      {
        title: "contaGrip",
        summary: "Grip to play in all conditions.",
        meaning:
          "Developed with Salomon engineers and athletes since 1994 (Salomon exclusive patent), contaGRIP® combines varying compounds with different lug designs optimized for each sport. It provides durable traction for all seasons in dry and wet conditions, see the dedicated chart to discover all our different contaGRIP® families.",
        image: "/salomon/glossary/other-contagrip.png",
      },
      {
        title: "Reverse Camber",
        summary: "Inspired by Salomon's ski heritage, this curved midsole geometry helps you feel like you are floating over the ground.",
        image: "/salomon/glossary/other-reverse-camber.png",
      },
      {
        title: "Made in France",
        summary: "Bringing production closer to consumers is essential to reduce our carbon footprint.",
        meaning: "The corresponding model has been assembled in the ASF 4.0 (automated shoe factory), located in Ardéche, France.",
        image: "/salomon/glossary/other-made-in-france.png",
      },
      {
        title: "recyclable Model",
        summary: "Scan the QR code on the upper or the box to register the pair and to send them back to us at the end of its life to be turned into another product.",
        image: "/salomon/glossary/other-recyclable-model.png",
      },
      {
        title: "relieveSpehere",
        summary: "relieveSPHERE technology designed to distribute pressure and absorb repetitive impact underfoot for lasting comfort.",
        meaning: "This pattern is derived from 6 years of research at the Salomon Sciences Laboratory.",
        image: "/salomon/glossary/other-relieve-sphere.png",
      },
      ],
    },
  {
    title: "Midsole Cushioning Foams",
    detail: "Foam and underfoot comfort stories.",
    panel: "rgba(244,243,240,0.96)",
    border: "rgba(109,96,82,0.18)",
    accent: "#6d6052",
    items: [
      {
        title: "Energy Cell",
        summary: "Salomon high performance EVA foam that provides shock attenuation.",
        meaning: "Salomon standard cushioning midsole system.",
        image: "/salomon/glossary/midsole-energy-cell.png",
      },
      {
        title: "Energy Cell+",
        summary: "A high-rebound midsole compound that provides exceptional energy return along with substantial cushioning and durability.",
        image: "/salomon/glossary/midsole-energy-cell-plus.png",
      },
      {
        title: "fuzeFOAM",
        summary: "An EVA compound engineered to use less artificial polymers.",
        meaning: "Composed of 30% natural rubber, smooth yet dynamic.",
        image: "/salomon/glossary/midsole-fuzefoam.png",
      },
      {
        title: "optiFOAM",
        summary: "Lightweight, super responsive cushioning.",
        meaning: "A foam created by combining EVA and Olefin [OBC] to deliver long-lasting cushion and bouncy energy return.",
        image: "/salomon/glossary/midsole-optifoam.png",
      },
      {
        title: "optiFOAM+",
        summary: "A lightweight foam with superior energy absorption and the most energy return.",
        meaning: "Responsive and cushioned for resilient bounce and pop in highly responsive shoes. The most responsive and bouncy foam.",
        image: "/salomon/glossary/midsole-optifoam-plus.png",
      },
      {
        title: "infiniFOAM",
        summary: "Nitrogen-infused TPU-based foam used on recyclable models such as INDEX.03.",
        meaning: "Position it as plush, long-lasting cushioning with a sustainability angle.",
        image: "/salomon/glossary/midsole-infinifoam.png",
      },
      {
        title: "optiFOAM²",
        summary: "optiFOAM² (100% TPU) is basically the best compromise for a training shoe.",
        meaning: "Performances are almost the same as optiFOAM+ (slightly less resilient and bouncy) but less expensive.",
        image: "/salomon/glossary/midsole-optifoam2.png",
      },
    ],
  },
  {
    title: "Chassis",
    detail: "Support and guidance stories.",
    panel: "rgba(241,242,241,0.96)",
    border: "rgba(93,100,93,0.18)",
    accent: "#586159",
    items: [
      {
        title: "advancedCHASSIS",
        summary: "A molded insert embedded in the outsole.",
        meaning: "Providing strong lateral support and reassuring protection, it also delivers optimal mobility and flexibility.",
        image: "/salomon/glossary/chassis-advanced-chassis.png",
      },
      {
        title: "activeCHASSIS",
        summary: "A chassis made from a stiffer and denser material than the midsole foam.",
        meaning: "Designed for increased guidance, uncompromised agility and fluid freedom of movement.",
        image: "/salomon/glossary/chassis-active-chassis.png",
      },
        {
          title: "4D CHASSIS",
          summary: "This stable chassis construction harnesses two different midsole components for enhanced foot control and active comfort.",
          meaning: "Found in our Quest 4.",
          image: "/salomon/glossary/chassis-4d-chassis.png",
        },
        {
          title: "SHANK",
          summary: "A molded piece between the outsole and the midsole that provides torsional rigidity and stability.",
          meaning: "At a lower level than a chassis.",
          image: "/salomon/glossary/shank.png",
        },
      ],
    },
  {
    title: "Ground Filter & Blades",
    detail: "Protection and structure for rougher ground.",
    panel: "rgba(245,244,240,0.96)",
    border: "rgba(138,117,82,0.18)",
    accent: "#7f6b4d",
    items: [
      {
        title: "energyBLADE",
        summary: "Lightweight, responsive plates connected to the midsole foam and sole geometry create an energy-infused alliance of velocity gain and smooth transitions.",
        meaning: "Fused into the sole, energyBLADE technology heightens your footwear experience by injecting power and propulsion into your stride.",
        image: "/salomon/glossary/ground-energy-blade.png",
      },
      {
        title: "PROFEEL FILM",
        summary: "Trail running protection.",
        meaning: "A thin TPU film placed between the midsole and the outsole that helps filter out rocks and sharp surfaces, for more comfort and stability without compromising on flexibility to keep a natural foot flexion and fluid ride.",
        image: "/salomon/glossary/ground-profeel-film.png",
      },
      {
        title: "PROFEEL PLATE",
        summary: "A hybrid between an energyBLADE and a ground filter.",
        meaning: "Used to filter out sharp objects while maintaining dynamism, ideal for long distance runs for when your foot becomes very sensible.",
        image: "/salomon/glossary/ground-profeel-plate.png",
      },
    ],
  },
  {
    title: "Upper",
    detail: "Fit-system stories.",
    panel: "rgba(243,242,240,0.96)",
    border: "rgba(117,103,89,0.18)",
    accent: "#6f6256",
    items: [
      {
        title: "quickLACE",
        summary: "Minimalist and strong lace (4 times stronger than regular flat laces) for one pull tightening.",
        meaning: "Easy-on, easy-off.",
        image: "/salomon/glossary/upper-quicklace.png",
      },
      {
        title: "sensiFIT",
        summary: "Foothold support.",
        meaning: "Cradles the foot from the midsole to the lacing system, providing a secure and snug fit all round the foot. Your foot seat belt.",
        image: "/salomon/glossary/upper-sensifit.png",
      },
      {
        title: "endoFIT",
        summary: "An internal fit sleeve designed to hug the foot in exactly the right places and provide a precise fit.",
        image: "/salomon/glossary/upper-endofit.png",
      },
      {
        title: "MATRYX",
        summary: "High tenacity fibers woven together to provide an ultra-resistant, ultra-breathable upper material.",
        image: "/salomon/glossary/upper-matryx.png",
      },
    ],
  },
  {
    title: "Upper Construction",
    detail: "Mesh and upper material stories.",
    panel: "rgba(241,243,243,0.96)",
    border: "rgba(89,104,110,0.18)",
    accent: "#56676c",
    items: [
      {
        title: "single layer MESH",
        summary: "A single layer of Mesh, close to the foot, for maximum feel, lightness, and breathability.",
        image: "/salomon/glossary/upper-construction-single-layer-mesh.png",
      },
      {
        title: "engineered MESH",
        summary: "Engineered mesh is a structure that varies the weave to offer more support and durability or flexibility and breathability, according to the specific needs of the shoe.",
        image: "/salomon/glossary/upper-construction-engineered-mesh.png",
      },
      {
        title: "3D MESH",
        summary: "With a unique and very precise design at thread level, our Custom Engineered Mesh delivers just the right balance of protection, foot hold, and breathability.",
        image: "/salomon/glossary/upper-construction-3d-mesh.png",
      },
      {
        title: "ripstop MESH",
        summary: "Woven fabrics, often made of nylon, with reinforcement to resist tearing, ripping and abrasion.",
        image: "/salomon/glossary/upper-construction-ripstop-mesh.png",
      },
    ],
  },
  {
    title: "Waterproof & Insulation",
    detail: "Weather and warmth stories.",
    panel: "rgba(239,242,243,0.96)",
    border: "rgba(94,109,117,0.18)",
    accent: "#5b6c73",
    items: [
      {
        title: "adv.DRY",
        image: "/salomon/glossary/waterproof-adv-dry.png",
        summary: "Salomon’s new 3-layer waterproof laminate featuring a PFC-free membrane secured between a 100% recycled face and backing fabric.",
      },
      {
        title: "adv.WARM",
        image: "/salomon/glossary/waterproof-adv-warm.png",
        summary: "Salomon’s new high-performance cold-weather insulation featuring 70% recycled.",
      },
      {
        title: "activ.WARM",
        image: "/salomon/glossary/waterproof-activ-warm.png",
        summary: "Our comfort insulation technology made with 90% recycled polyester.",
        meaning: "A lightweight insulation layer covers the mid-foot and toe area to create warmth in the most essential areas.",
      },
    ],
  },
];

const dareSteps = [
  "Divide the team into two groups: customers and sales associates.",
  "Form two lines facing each other.",
  "Customers each hide a random object behind their back.",
  "Sales associates have up to 10 seconds to break the ice with one sentence based on that object.",
  "Walk forward, swap roles, and repeat.",
  "Debrief what felt easy to connect, what felt difficult, and what made the customer react.",
];

const sectionPadding = "p-6 md:p-8 lg:p-10";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Module 1 | Brand story, history, and tech legends</title>
  </head>
  <body class="selection:bg-[var(--sal-lime)] selection:text-black">
    <main class="sal-shell min-h-screen">
      <div class="mx-auto max-w-[1260px] px-4 pt-2 pb-4 md:px-6 md:pt-3 md:pb-6">
        <header class="sal-card sal-section sticky top-2 z-30 overflow-visible px-4 py-4 md:top-3 md:px-6" style="z-index:60; isolation:isolate;">
          <div class="flex items-center justify-between gap-4 md:hidden">
            <div class="flex min-w-0 items-center gap-3">
              <img src="/tfg-logo.svg" alt="TFG logo" class="h-10 w-10 shrink-0" />
              <p class="min-w-0 text-sm font-medium leading-5 text-[var(--sal-ink-soft)]">Module 1 | Brand story, history, and tech legends</p>
            </div>

            <details class="relative z-[70] shrink-0 md:hidden" data-mobile-nav style="z-index:70;">
              <summary class="flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-full border border-[rgba(12,12,12,0.1)] bg-white text-[var(--sal-ink-soft)] transition hover:bg-[#f4efea] [&::-webkit-details-marker]:hidden">
                <span class="sr-only">Toggle lesson navigation</span>
                <span aria-hidden="true" class="flex flex-col gap-[0.28rem]">
                  <span class="block h-[2px] w-5 rounded-full bg-current"></span>
                  <span class="block h-[2px] w-5 rounded-full bg-current"></span>
                  <span class="block h-[2px] w-5 rounded-full bg-current"></span>
                </span>
              </summary>

              <div class="absolute right-0 top-[calc(100%+0.75rem)] z-[80] w-64 max-w-[calc(100vw-1.5rem)] overflow-hidden rounded-[0.9rem] border border-[rgba(12,12,12,0.08)] bg-white p-2 shadow-[0_14px_36px_rgba(56,39,27,0.09)]" style="z-index:80;">
                <div class="flex flex-col gap-1.5 text-sm text-[var(--sal-ink-soft)]">
                  {navItems.map((item) => (
                    <a href={item.href} class="rounded-[0.75rem] px-4 py-3 transition hover:bg-[#f4efea]" data-mobile-nav-link>{item.label}</a>
                  ))}
                </div>
              </div>
            </details>
          </div>

          <div class="hidden md:flex md:items-center md:justify-between md:gap-6">
            <div class="flex min-w-0 items-center gap-4">
              <img src="/tfg-logo.svg" alt="TFG logo" class="h-11 w-11 shrink-0" />
              <div class="min-w-0">
                <p class="text-lg font-semibold tracking-[-0.03em] text-[var(--sal-ink-soft)]">Module 1 | Brand story, history, and tech legends</p>
              </div>
            </div>

            <nav class="flex gap-2 overflow-x-auto pb-1 text-[0.78rem] font-bold uppercase tracking-[0.12em] text-[var(--sal-ink-soft)]">
              {navItems.map((item) => (
                <a href={item.href} class="sal-chip whitespace-nowrap hover:border-[rgba(12,12,12,0.22)] hover:bg-white">{item.label}</a>
              ))}
            </nav>
          </div>
        </header>

        <section class="sal-card-dark sal-section mt-5 overflow-hidden px-6 py-8 md:mt-6 md:px-10 md:py-12">
          <div class="grid gap-8 lg:grid-cols-[1.18fr_0.82fr] lg:items-end">
            <div>
              <p class="sal-kicker text-[var(--sal-lime)]">Start here</p>
              <h1 class="mt-4 max-w-[13ch] text-[2.95rem] font-black uppercase leading-[0.92] tracking-[-0.07em] text-white md:text-[4.95rem]">
                the salomon story
              </h1>
              <p class="mt-5 max-w-[46rem] text-[1.08rem] leading-8 text-white/78 md:text-[1.18rem]">
                Get clear on what the brand stands for, where it comes from, the technology terms that matter, and the selling habits that help customers trust your recommendation.
              </p>

            </div>

            <div class="sal-hero-photo">
              <img src={resolveSalomonImage("/salomon/hero-brand.png")} alt="Two Salomon runners moving through an elevated natural landscape" />
            </div>
          </div>
        </section>

        <section id="overview" class="sal-card sal-section mt-6">
          <div class={sectionPadding}>
            <div>
              <div>
                <p class="sal-kicker text-[#6a6257]">In this course</p>
                <h2 class="mt-3 text-[2.2rem] font-black uppercase leading-[0.95] tracking-[-0.06em] text-[var(--sal-ink)] md:text-[3.1rem]">
                  The four modules in this course
                </h2>
                <div class="mt-8 grid gap-4 md:grid-cols-2">
                  {moduleGuide.map((item) => (
                    <article
                      class="flex min-h-[11.5rem] flex-col justify-end overflow-hidden rounded-[0.5625rem] border border-white/10 p-6 text-white shadow-[0_18px_36px_rgba(12,12,12,0.08)] md:min-h-[12.5rem] md:p-6"
                      style={`background-image:url(${resolveSalomonImage(item.image)}); background-size:cover; background-position:center;`}
                    >
                      <div class="inline-flex max-w-[19rem] flex-col gap-2 rounded-[0.5625rem] border border-white/10 bg-black/58 px-4 py-3 backdrop-blur-[2px]">
                        <p class="sal-kicker text-white/72">{item.module}</p>
                        <h3 class="text-[1.2rem] font-semibold tracking-[-0.03em] text-white">{item.title}</h3>
                      </div>
                    </article>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="sal-section mt-6 overflow-hidden rounded-[0.5625rem]">
          <div class="sal-photo-strip aspect-[16/6] md:aspect-[18/6]" style="border:none;">
            <img src={whoWeAreBanner} alt="Mountain landscape from Salomon brand imagery" />
          </div>
        </section>

        <section id="positioning" class="sal-card sal-section mt-6">
          <div class={sectionPadding}>
            <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
              <div>
                <p class="sal-kicker text-[#6a6257]">Brand positioning</p>
                <h2 class="sal-topo-divider mt-3 inline-block text-[2.3rem] font-black uppercase leading-[0.94] tracking-[-0.06em] text-[var(--sal-ink)] md:text-[3.35rem]">
                  Premium, innovative, authentic
                </h2>
                <div class="mt-6 rounded-[0.5625rem] border border-[rgba(12,12,12,0.08)] bg-[#181818] p-6 text-white">
                  <p class="sal-kicker text-[var(--sal-lime)]">The line to remember</p>
                  <p class="mt-4 text-[1.35rem] font-semibold uppercase leading-8 tracking-[-0.03em]">WE ARE THE MOST PREMIUM, INNOVATIVE AND AUTHENTIC BRAND FOR THE MOUNTAIN SPORT LIFESTYLE</p>
                </div>
              </div>

              <div class="grid gap-4 md:grid-cols-3">
                {positioningPillars.map((pillar, index) => (
                  <article
                    class="rounded-[0.5625rem] border border-[rgba(12,12,12,0.08)] p-5 shadow-[0_18px_36px_rgba(12,12,12,0.05)]"
                    style={`background:${index === 0 ? "rgba(247,246,243,0.96)" : index === 1 ? "rgba(242,241,238,0.96)" : "rgba(245,244,241,0.96)"};`}
                  >
                    <h3 class="text-[1.45rem] font-black uppercase tracking-[-0.05em] text-[var(--sal-ink)]">{pillar.title}</h3>
                    <p class="mt-3 text-sm leading-7 text-[#423f38]">{pillar.detail}</p>
                  </article>
                ))}
              </div>
            </div>
          </div>
        </section>

        <section id="timeline" class="sal-card sal-section mt-6">
          <div class={sectionPadding}>
            <div>
              <div class="sal-history-hero">
                <video
                  src={whoWeAreVideoOne}
                  autoplay
                  muted
                  loop
                  playsinline
                  preload="metadata"
                  aria-label="Looping Salomon brand video showing movement in mountain terrain"
                ></video>
                <div class="sal-history-hero__content">
                  <p class="sal-kicker text-white/72">Brand history</p>
                  <h2 class="mt-3 max-w-[12ch] text-[2.2rem] font-black uppercase leading-[0.95] tracking-[-0.06em] text-white md:text-[3.2rem]">
                    From mountain roots to icons customers ask for by name
                  </h2>
                </div>
              </div>

              <div class="mt-7">
                <div class="sal-history-stack xl:pt-1">
                  {timeline.map((item) => (
                    <article class="sal-history-entry">
                      <div class="sal-history-entry__year">
                        <span class="sal-history-year">{item.year}</span>
                      </div>
                      <div class:list={["sal-history-card", item.image && "sal-history-card--image"]}>
                        <div class:list={["grid gap-4", item.image && "lg:grid-cols-[1fr_10.5rem] lg:items-center"]}>
                          <div>
                            <h3 class="text-[1.28rem] font-semibold tracking-[-0.03em] text-[var(--sal-ink)]">{item.title}</h3>
                            {item.detail && <p class="mt-3 text-sm leading-7 text-[#46423c]">{item.detail}</p>}
                          </div>

                          {item.image && (
                            <div class="sal-history-photo">
                              <img src={resolveSalomonImage(item.image)} alt={`${item.title} Salomon product visual`} />
                            </div>
                          )}
                        </div>
                      </div>
                    </article>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="sal-section mt-6 overflow-hidden rounded-[0.5625rem]">
          <div class="sal-photo-strip aspect-[16/6] md:aspect-[18/6]" style="border:none;">
            <img src={productBanner} alt="Salomon product banner imagery" />
          </div>
        </section>

        <section id="legends" class="sal-card sal-section mt-6">
          <div class={sectionPadding}>
            <p class="sal-kicker text-[#6a6257]">Salomon tech legends</p>
            <h2 class="mt-3 text-[2.15rem] font-black uppercase leading-[0.96] tracking-[-0.06em] text-[var(--sal-ink)] md:text-[3rem]">
              The glossary that helps the range make sense
            </h2>

            <div class="mt-8 grid gap-6">
              {legendGroups.map((group) => (
                <section
                  data-carousel
                  class="min-w-0 overflow-hidden rounded-[0.5625rem] border p-5 md:p-6"
                  style={`background:${group.panel}; border-color:${group.border};`}
                >
                  <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
                    <div>
                      <div class="mb-4 h-[2px] w-14 rounded-full" style={`background:${group.accent};`}></div>
                      <h3 class="text-[1.5rem] font-black uppercase tracking-[-0.05em] text-[var(--sal-ink)]">{group.title}</h3>
                    </div>
                  </div>

                  <div class="sal-carousel-shell mt-6">
                    <div class="sal-carousel-viewport">
                      <div
                        class="sal-carousel-track"
                        data-track
                        aria-label={`${group.title} glossary items`}
                        onpointerdown="if(event.button!==0){return;} this.dataset.dragging='true'; this.dataset.startX=String(event.clientX); this.dataset.startScroll=String(this.scrollLeft); this.classList.add('is-dragging'); this.setPointerCapture(event.pointerId);"
                        onpointermove="if(this.dataset.dragging==='true'){ const startX=Number(this.dataset.startX||0); const startScroll=Number(this.dataset.startScroll||0); this.scrollLeft=startScroll-(event.clientX-startX); }"
                        onpointerup="this.dataset.dragging='false'; this.classList.remove('is-dragging'); if(this.hasPointerCapture && this.hasPointerCapture(event.pointerId)){ this.releasePointerCapture(event.pointerId); }"
                        onpointercancel="this.dataset.dragging='false'; this.classList.remove('is-dragging'); if(this.hasPointerCapture && this.hasPointerCapture(event.pointerId)){ this.releasePointerCapture(event.pointerId); }"
                        onlostpointercapture="this.dataset.dragging='false'; this.classList.remove('is-dragging');"
                      >
                        {group.items.map((legend) => (
                          <article class="sal-carousel-card rounded-[0.5625rem] border border-[rgba(12,12,12,0.08)] bg-white/92 p-5">
                            {legend.image && (
                              <div class="mb-4 px-2">
                                <div class="flex min-h-[3.25rem] items-center justify-center">
                                  <img src={resolveSalomonImage(legend.image)} alt={`${legend.title} glossary icon`} class="max-h-12 max-w-full object-contain" />
                                </div>
                                <div class="mt-3 h-px w-full bg-[rgba(12,12,12,0.1)]"></div>
                              </div>
                            )}
                            <h4 class="text-[1.12rem] font-semibold tracking-[-0.03em] text-[var(--sal-ink)]">{legend.title}</h4>
                            <p class="mt-3 text-sm leading-7 text-[#403b34]">{legend.summary}</p>
                            {legend.meaning && <p class="mt-4 text-sm leading-7 text-[#47433d]">{legend.meaning}</p>}
                          </article>
                        ))}
                      </div>
                    </div>
                  </div>
                </section>
              ))}
            </div>
          </div>
        </section>

      </div>
    </main>
    <script>
      const mobileNavs = document.querySelectorAll("[data-mobile-nav]");

      document.addEventListener("click", (event) => {
        mobileNavs.forEach((menu) => {
          if (!menu.contains(event.target)) {
            menu.removeAttribute("open");
          }
        });
      });

      mobileNavs.forEach((menu) => {
        menu.querySelectorAll("[data-mobile-nav-link]").forEach((link) => {
          link.addEventListener("click", () => {
            menu.removeAttribute("open");
          });
        });
      });
    </script>
  </body>
</html>
