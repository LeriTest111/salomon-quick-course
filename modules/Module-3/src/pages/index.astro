---
import "../styles/global.css";
import whiteLogo from "../images/White-logo.svg?url";

const salomonImages = import.meta.glob("../images/salomon/**/*.{png,jpg,jpeg,avif,svg}", {
  eager: true,
  query: "?url",
  import: "default",
});

const resolveSalomonImage = (path) =>
  path.startsWith("/salomon/")
    ? salomonImages[`../images/salomon/${path.slice("/salomon/".length)}`] ?? path
    : path;

const navItems = [
  { href: "#groups", label: "Road models" },
  { href: "#lineup", label: "Lineup" },
  { href: "#sell", label: "Sell it" },
];

const roadGroups = [
  {
    title: "Dynamic comfort",
    models: "Aero Glide 4, Aero Blaze 3",
    detail: "For long-distance runners and everyday runners seeking cushioning, smooth transitions, and dynamic comfort.",
    bestFor: ["Easy to moderate pace", "Smooth running feel", "Cushion and bounce"],
    tone: "rgba(247,246,243,0.96)",
  },
  {
    title: "Dynamic speed",
    models: "S/LAB Phantasm 3",
    detail: "For fast-paced runners chasing performance, energy return, and a lighter, more propulsive road feeling.",
    bestFor: ["Running fast", "Propulsion", "Performance training and competition"],
    tone: "rgba(242,241,238,0.96)",
  },
];

const coreProducts = [
  {
    title: "Aero Glide 4",
    image: "/salomon/aero-glide-4.png",
    lane: "Dynamic comfort",
    group: "Dynamic comfort",
    strap: "The iconic premium comfort road model",
    metrics: ["Long-distance comfort", "Premium cushioning", "Cushion and bounce", "Everyday road use"],
    detail:
      "Aero Glide 4 is the premium comfort answer for long-distance runners and everyday runners who want cushioning and smooth, easy miles.",
    specs: [
      { label: "Use", lines: ["Long distance", "Everyday road"] },
      { label: "Ride", lines: ["Soft cushioning", "Smooth transitions"] },
      { label: "Feel", lines: ["Premium comfort"] },
      { label: "Runner", lines: ["Comfort-led", "Mileage-focused"] },
    ],
    benefits: ["Premium cushioning", "Smooth transitions", "Long-run comfort"],
    say: "Use Aero Glide 4 for runners who want the plushest, most comfort-led road feeling in the range.",
  },
  {
    title: "Aero Blaze 3",
    image: "/salomon/aero-blaze-3.png",
    lane: "Dynamic comfort",
    group: "Dynamic comfort",
    strap: "Made for everyone, a reliable everyday running shoe",
    metrics: ["Dynamic comfort", "Fluid transitions", "High comfort fit", "Versatile road training"],
    detail:
      "Aero Blaze 3 is the one shoe that nails every session. It mixes cushioning, dynamic comfort, and smooth transitions in a lightweight construction with premium-feel performance.",
    specs: [
      { label: "Drop", lines: ["8 mm", "35 / 27mm"] },
      {
        label: "Weight",
        columns: [
          { value: "230 g", note: "M UK 8.5" },
          { value: "193 g", note: "W UK 5.5" },
        ],
      },
      { label: "Cushion", lines: ["Regular"] },
      { label: "Practice", lines: ["Running"] },
      { label: "Terrain", lines: ["Road"] },
      { label: "Fit", lines: ["Standard"] },
    ],
    benefits: ["Versatile performance", "Lightweight comfort", "Smooth daily running"],
    say: "Frame Aero Blaze 3 as the go-to road shoe: very good at everything, versatile, light, and dynamic.",
  },
  {
    title: "S/LAB Phantasm 3",
    image: "/salomon/slab-phantasm-3.png",
    lane: "Dynamic speed",
    group: "Dynamic speed",
    strap: "The road answer for maximum propulsion",
    metrics: ["Performance training", "Competition", "Lightweight propulsion", "Dynamic speed"],
    detail:
      "S/LAB Phantasm 3 is the speed answer for runners who want maximum energy return, lighter-feeling speed, and a stronger performance-training point of view.",
    specs: [
      { label: "Use", lines: ["Performance training", "Competition"] },
      { label: "Ride", lines: ["Propulsive", "Fast turnover"] },
      { label: "Feel", lines: ["Lightweight speed"] },
      { label: "Runner", lines: ["Performance-led"] },
    ],
    benefits: ["Fast ride feel", "Energy return", "Race-day mindset"],
    say: "Lead with S/LAB Phantasm 3 when the customer wants to run fast and clearly identifies as performance-minded rather than comfort-led.",
  },
];

const lineupSections = [
  {
    title: "Dynamic comfort",
    intro: "Dynamic comfort is for road runners who want smooth cushioning, everyday versatility, and easy miles. Start here with Aero Glide 4 and Aero Blaze 3.",
    products: ["Aero Glide 4", "Aero Blaze 3"],
  },
  {
    title: "Dynamic speed",
    intro: "Dynamic speed is for runners who clearly want propulsion, performance training, and a faster road feeling. Start here with S/LAB Phantasm 3.",
    products: ["S/LAB Phantasm 3"],
  },
];

const moreRoadProducts = [
  {
    title: "S/LAB Phantasm 2 Made in France",
    image: "/salomon/road-phantasm-2-made-in-france.png",
    row: "S/LAB Proracing concept",
    group: "Dynamic speed",
    detail: "Part of the S/LAB Proracing concept within the road range.",
  },
  {
    title: "S/LAB Spectur",
    image: "/salomon/road-spectur.png",
    row: "S/LAB Proracing concept",
    group: "Dynamic speed",
    detail: "Another speed-led S/LAB option in the road range.",
  },
  {
    title: "Spectur 3",
    image: "/salomon/road-spectur-3.png",
    row: "Performance and racing",
    group: "Dynamic speed",
    detail: "A performance and racing option for runners looking for a faster road shoe.",
  },
  {
    title: "INDEX.03",
    image: "/salomon/road-index-03.png",
    row: "Recreational multi-activity",
    group: "Dynamic comfort",
    detail: "A comfort-led option for broader recreational and multi-activity use.",
  },
];

const sellingRows = [
  {
    prompt: "I just want one great road shoe for most runs.",
    start: "Aero Blaze 3",
    why: "Aero Blaze 3 is the reliable everyday-running answer and the broadest road recommendation in the pack.",
  },
  {
    prompt: "I want the plushest, easiest comfort ride.",
    start: "Aero Glide 4",
    why: "Aero Glide 4 is the clearest answer for premium cushion and bounce.",
  },
  {
    prompt: "I care about speed, energy return, and race-day feeling.",
    start: "S/LAB Phantasm 3",
    why: "That request points directly to the speed side of the range and the S/LAB Phantasm 3 story.",
  },
];

const conversationOpeners = [
  "What kind of run are you shopping for most?",
  "Do you want the ride to feel softer and easier, or faster and more responsive?",
  "Is this mainly for everyday runs, longer comfort runs, or speed sessions?",
  "Do you want one shoe for most runs, or something more performance-led?",
];

const dareSteps = [
  "Divide the team into two groups: Customers and Sales Associates.",
  "Form two lines facing each other.",
  "Customers each hide a random object behind their back.",
  "Sales associates have up to 10 seconds to break the ice with one sentence based on that object.",
  "Walk forward, swap roles, and repeat.",
  "Debrief what felt easy to connect, what felt difficult, and what made the customer react.",
];

const sectionPadding = "p-6 md:p-8 lg:p-10";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Module 3 | Road running</title>
  </head>
  <body class="selection:bg-[var(--sal-lime)] selection:text-black">
    <main class="sal-shell min-h-screen">
      <div class="sal-fixed-nav fixed inset-x-0 top-0 z-[90]">
        <header class="sal-section overflow-visible px-4 py-4 md:px-6 lg:px-[8vw]" style="z-index:90; isolation:isolate;">
          <div class="flex items-center justify-between gap-4 md:hidden">
            <div class="flex min-w-0 items-center gap-3">
              <img src="/tfg-logo.svg" alt="TFG logo" class="h-10 w-10 shrink-0" />
              <p class="sal-ui-text min-w-0 font-medium text-[var(--sal-ink-soft)]">Module 3 | Road running</p>
            </div>

            <details class="relative z-[70] shrink-0 md:hidden" data-mobile-nav style="z-index:70;">
              <summary class="flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-full border border-[rgba(12,12,12,0.1)] bg-white text-[var(--sal-ink-soft)] transition hover:bg-[#f4efea] [&::-webkit-details-marker]:hidden">
                <span class="sr-only">Toggle lesson navigation</span>
                <span aria-hidden="true" class="flex flex-col gap-[0.28rem]">
                  <span class="block h-[2px] w-5 rounded-full bg-current"></span>
                  <span class="block h-[2px] w-5 rounded-full bg-current"></span>
                  <span class="block h-[2px] w-5 rounded-full bg-current"></span>
                </span>
              </summary>

              <div class="absolute right-0 top-[calc(100%+0.75rem)] z-[80] w-64 max-w-[calc(100vw-1.5rem)] overflow-hidden rounded-[0.9rem] border border-[rgba(12,12,12,0.08)] bg-white p-2 shadow-[0_14px_36px_rgba(56,39,27,0.09)]" style="z-index:80;">
                <div class="sal-ui-text flex flex-col gap-1.5 text-[var(--sal-ink-soft)]">
                  {navItems.map((item) => (
                    <a href={item.href} class="rounded-[0.75rem] px-4 py-3 transition hover:bg-[#f4efea]" data-mobile-nav-link>{item.label}</a>
                  ))}
                </div>
              </div>
            </details>
          </div>

          <div class="hidden md:flex md:items-center md:justify-between md:gap-6">
            <div class="flex min-w-0 items-center gap-4">
              <img src="/tfg-logo.svg" alt="TFG logo" class="h-11 w-11 shrink-0" />
              <div class="min-w-0">
                <p class="sal-body-copy font-semibold tracking-[-0.03em] text-[var(--sal-ink-soft)]">Module 3 | Road running</p>
              </div>
            </div>

            <nav class="sal-ui-text flex gap-2 overflow-x-auto pb-1 font-bold uppercase tracking-[0.12em] text-[var(--sal-ink-soft)]">
              {navItems.map((item) => (
                <a href={item.href} class="sal-chip whitespace-nowrap hover:border-[rgba(12,12,12,0.22)] hover:bg-white">{item.label}</a>
              ))}
            </nav>
          </div>
        </header>
      </div>

      <div class="w-full pb-4 pt-24 md:pb-6 md:pt-28">
        <section
          class="sal-card-dark sal-section sal-hero-banner mt-5 overflow-hidden px-6 py-8 md:mt-6 md:px-10 md:py-12"
        >
          <div class="sal-hero-banner__media" aria-hidden="true">
            <img src={resolveSalomonImage("/salomon/hero-road.png")} alt="" class="sal-hero-banner__image" />
          </div>
          <div class="grid gap-8 lg:grid-cols-[1.08fr_0.92fr] lg:items-end">
            <div class="sal-hero-stack">
              <div class="sal-hero-lockup">
                <img src={whiteLogo} alt="Salomon logo" class="sal-hero-logo" />
                <span class="sal-module-pill">Module 3</span>
              </div>
              <p class="sal-kicker text-[var(--sal-pink)]">Road running</p>
              <h1 class="sal-title-hero text-white">
                Start road conversations with feel
              </h1>
              <p class="sal-body-copy text-white/78">
                Most road runners are looking for one of two things: smoother comfort or faster response. Start there, then guide them to the right shoe.
              </p>
            </div>
          </div>
        </section>

        <section id="groups" class="sal-card sal-section mt-0 scroll-mt-28 md:scroll-mt-32">
          <div class={sectionPadding}>
            <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
              <div>
                <p class="sal-kicker text-[#6a6257]">Start here</p>
                <h2 class="sal-topo-divider sal-title-section mt-3 text-[var(--sal-ink)]">
                  Most road runners want comfort or speed
                </h2>
                <p class="sal-body-copy mt-5 text-[#444039]">
                  Start the conversation by finding out whether the runner wants smoother comfort or a faster, more propulsive feel. Once that is clear, the right road model becomes much easier to recommend. The following are key Salomon road running models and who they are for.
                </p>
              </div>
            </div>

            <div class="mt-8 grid gap-4 md:grid-cols-2">
              {roadGroups.map((group, index) => (
                <article
                  class="flex h-full flex-col rounded-[0.5625rem] border border-[rgba(12,12,12,0.08)] p-5"
                  style={`background:${index === 0 ? "rgba(247,246,243,0.96)" : "rgba(242,241,238,0.96)"};`}
                >
                  <h3 class="sal-title-product uppercase text-[var(--sal-ink)]">{group.title}</h3>
                  <p class="sal-ui-text mt-3 font-semibold uppercase tracking-[0.12em] text-[#5d584f]">{group.models}</p>
                  <p class="sal-body-copy mt-4 text-[#444039]">{group.detail}</p>
                  <ul class="sal-body-copy mt-4 space-y-2 text-[#403b34]">
                    {group.bestFor.map((item) => (
                      <li class="flex gap-2"><span class="mt-[0.58rem] h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--sal-ink)]"></span><span>{item}</span></li>
                    ))}
                  </ul>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section class="sal-section mt-6 overflow-hidden">
          <div class="sal-photo-strip sal-course-banner">
            <img
              src={resolveSalomonImage("/salomon/roadrunning2.jpg")}
              alt="Road runners in motion"
              class="sal-course-banner-image"
            />
          </div>
        </section>

        <section id="lineup" class="sal-card sal-section mt-0 scroll-mt-28 md:scroll-mt-32">
          <div class={sectionPadding}>
            <p class="sal-kicker text-[#6a6257]">Road lineup</p>
            <h2 class="sal-topo-divider sal-title-section mt-3 text-[var(--sal-ink)]">
              The full road running range
            </h2>
            <p class="sal-body-copy mt-5 text-[#45413b]">
              Click each shoe to reveal more product detail.
            </p>
            <div class="mt-8 grid gap-5">
              {lineupSections.map((section, sectionIndex) => (
                <section
                  class={sectionIndex % 2 === 1
                    ? "rounded-[0.5625rem] border border-white/10 bg-[linear-gradient(140deg,rgba(24,24,24,0.96)_0%,rgba(10,10,10,0.98)_100%)] p-5 text-white md:p-6"
                    : "rounded-[0.5625rem] border border-[rgba(12,12,12,0.08)] bg-[#f3f1ed] p-5 md:p-6"}
                >
                  <div>
                    <p class={sectionIndex % 2 === 1 ? "sal-kicker text-white" : "sal-kicker text-[#6a6257]"}>{section.title}</p>
                    <p class={sectionIndex % 2 === 1 ? "sal-body-copy mt-3 text-white" : "sal-body-copy mt-3 text-[#45413b]"}>{section.intro}</p>
                  </div>

                  <div class="mt-5 grid gap-5">
                  {coreProducts
                    .filter((product) => section.products.includes(product.title))
                    .map((product) => (
                      <details
                        class={sectionIndex % 2 === 1 ? "sal-model-card sal-model-card--dark p-5 md:p-6" : "sal-model-card p-5 md:p-6"}
                        style={sectionIndex % 2 === 1
                          ? "background:linear-gradient(140deg, rgba(58, 58, 58, 0.96) 0%, rgba(36, 36, 36, 0.98) 100%); border-color:rgba(255,255,255,0.1); color:white;"
                          : "background:white;"}
                        name={`road-shoe-${section.title}`}
                      >
                        <summary class="sal-product-reveal-summary">
                        <div class="grid gap-6 xl:grid-cols-[0.72fr_1.28fr] xl:items-start">
                          <div>
                            <div class="sal-product-stage">
                              <img src={resolveSalomonImage(product.image)} alt={`${product.title} product visual`} />
                            </div>
                          </div>

                          <div class={sectionIndex % 2 === 1 ? "sal-model-card__header border-white/10" : "sal-model-card__header"}>
                            <h3 class={sectionIndex % 2 === 1 ? "sal-title-product mt-3 text-white" : "sal-title-product mt-3 text-[var(--sal-ink)]"}>{product.title}</h3>
                            <p class={sectionIndex % 2 === 1 ? "sal-ui-text mt-3 font-semibold uppercase tracking-[0.12em] text-white" : "sal-ui-text mt-3 font-semibold uppercase tracking-[0.12em] text-[#5d584f]"}>{product.strap}</p>
                            <p class={sectionIndex % 2 === 1 ? "sal-body-copy mt-4 text-white" : "sal-body-copy mt-4 text-[#45413b]"}>{product.detail}</p>
                            <span class={sectionIndex % 2 === 1 ? "sal-product-reveal-summary__cta sal-product-reveal-summary__cta--dark" : "sal-product-reveal-summary__cta"}>Reveal more</span>
                          </div>
                        </div>
                        </summary>

                        <div class="sal-product-reveal-body">
                        <div class="mt-4 flex flex-wrap gap-2">
                          {product.metrics.map((metric) => (
                            <span class={sectionIndex % 2 === 1
                              ? "rounded-[0.5625rem] border border-white/10 bg-white/8 px-3 py-2 text-[18px] font-bold uppercase tracking-[0.12em] text-white"
                              : "rounded-[0.5625rem] border border-[rgba(12,12,12,0.08)] bg-[#f8f7f4] px-3 py-2 text-[18px] font-bold uppercase tracking-[0.12em] text-[#5e574d]"}>
                              {metric}
                            </span>
                          ))}
                        </div>

                        <div class="mt-4 grid gap-4 xl:grid-cols-[3fr_1fr]">
                          <div class={sectionIndex % 2 === 1
                            ? "rounded-[0.5625rem] border border-white/10 bg-[linear-gradient(140deg,rgba(92,92,92,0.96)_0%,rgba(66,66,66,0.98)_100%)] p-4 text-white"
                            : "rounded-[0.5625rem] bg-[#f0efeb] p-4"}>
                          <p class={sectionIndex % 2 === 1 ? "text-[18px] font-bold uppercase tracking-[0.14em] text-white" : "text-[18px] font-bold uppercase tracking-[0.14em] text-[#71695d]"}>Tech features</p>
                          <div class="mt-4 sal-spec-grid">
                            {product.specs.map((spec) => (
                              <article class={sectionIndex % 2 === 1 ? "sal-spec-card border-white/12" : "sal-spec-card"}>
                                <p class={sectionIndex % 2 === 1 ? "sal-spec-label text-white/64" : "sal-spec-label"}>{spec.label}</p>
                                {spec.columns ? (
                                  <div class="sal-spec-columns">
                                    {spec.columns.map((column) => (
                                      <div class="sal-spec-stack">
                                        <p class={sectionIndex % 2 === 1 ? "sal-spec-value sal-spec-value--inline text-white" : "sal-spec-value sal-spec-value--inline"}>
                                          {column.value}
                                          {column.note && <span class={sectionIndex % 2 === 1 ? "sal-spec-note text-white/78" : "sal-spec-note"}>{` - ${column.note}`}</span>}
                                        </p>
                                      </div>
                                    ))}
                                  </div>
                                ) : (
                                  <div class="sal-spec-stack">
                                    {spec.lines.map((line) => (
                                      <p class={sectionIndex % 2 === 1 ? "sal-spec-value text-white" : "sal-spec-value"}>{line}</p>
                                    ))}
                                  </div>
                                )}
                              </article>
                            ))}
                          </div>
                          </div>

                          <div class={sectionIndex % 2 === 1
                            ? "rounded-[0.5625rem] border border-white/10 bg-[linear-gradient(140deg,rgba(92,92,92,0.96)_0%,rgba(66,66,66,0.98)_100%)] p-4 text-white"
                            : "rounded-[0.5625rem] bg-white p-4"}>
                          <p class={sectionIndex % 2 === 1 ? "text-[18px] font-bold uppercase tracking-[0.14em] text-white" : "text-[18px] font-bold uppercase tracking-[0.14em] text-[#71695d]"}>Key features</p>
                          <ul class={sectionIndex % 2 === 1 ? "mt-3 space-y-2 text-[18px] leading-8 text-white" : "mt-3 space-y-2 text-[18px] leading-8 text-[#403b34]"}>
                            {product.benefits.map((item) => (
                              <li class="flex gap-2"><span class={sectionIndex % 2 === 1 ? "mt-[0.58rem] h-1.5 w-1.5 shrink-0 rounded-full bg-white/64" : "mt-[0.58rem] h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--sal-pink)]"}></span><span>{item}</span></li>
                            ))}
                          </ul>
                          {product.tech && (
                            <div class="mt-4">
                              <p class={sectionIndex % 2 === 1 ? "text-[18px] font-bold uppercase tracking-[0.14em] text-white" : "text-[18px] font-bold uppercase tracking-[0.14em] text-[#71695d]"}>Technologies</p>
                              <ul class={sectionIndex % 2 === 1 ? "mt-3 space-y-2 text-[18px] leading-8 text-white" : "mt-3 space-y-2 text-[18px] leading-8 text-[#403b34]"}>
                                {product.tech.map((item) => (
                                  <li class="flex gap-2"><span class={sectionIndex % 2 === 1 ? "mt-[0.58rem] h-1.5 w-1.5 shrink-0 rounded-full bg-white/64" : "mt-[0.58rem] h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--sal-ink)]"}></span><span>{item}</span></li>
                                ))}
                              </ul>
                            </div>
                          )}
                          </div>
                        </div>

                        <div class={sectionIndex % 2 === 1
                          ? "mt-4 rounded-[0.5625rem] border border-white/10 bg-[linear-gradient(140deg,rgba(92,92,92,0.96)_0%,rgba(66,66,66,0.98)_100%)] p-4 text-white"
                          : "mt-4 rounded-[0.5625rem] border border-[rgba(12,12,12,0.08)] bg-[#151515] p-4 text-white"}>
                          <p class={sectionIndex % 2 === 1 ? "text-[18px] font-bold uppercase tracking-[0.14em] text-white" : "text-[18px] font-bold uppercase tracking-[0.14em] text-white"}>What to say</p>
                          <p class={sectionIndex % 2 === 1 ? "mt-2 text-[18px] leading-8 text-white" : "mt-2 text-[18px] leading-8 text-white"}>{product.say}</p>
                        </div>
                        </div>
                      </details>
                    ))}
                  </div>
                </section>
              ))}
            </div>

            <section class="mt-6">
              <div class="rounded-[0.5625rem] border border-[rgba(12,12,12,0.08)] bg-[#f3f1ed] p-5 md:p-6">
                <p class="sal-kicker text-[#6a6257]">More road shoes</p>
                <p class="sal-body-copy mt-3 text-[#45413b]">
                  These are supporting road models to know when the customer wants a more specific race, speed, or multi-activity option.
                </p>

                <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
                  {moreRoadProducts.map((product) => (
                    <article class="sal-model-card bg-white p-5 md:p-6">
                      <div class="sal-product-stage mb-5 p-4">
                        <img src={resolveSalomonImage(product.image)} alt={`${product.title} product visual`} class="max-h-[13.5rem] max-w-[92%]" />
                      </div>
                      <h3 class="text-[1.18rem] font-semibold tracking-[-0.03em] text-[var(--sal-ink)]">{product.title}</h3>
                      <p class="mt-2 text-[18px] font-bold uppercase tracking-[0.14em] text-[#71695d]">{product.row}</p>
                      <p class="sal-body-copy mt-4 text-[#47433d]">{product.detail}</p>
                    </article>
                  ))}
                </div>
              </div>
            </section>
          </div>
        </section>

        <section id="sell" class="sal-section mt-6 grid gap-4 scroll-mt-28 lg:grid-cols-[0.88fr_1.12fr] md:scroll-mt-32">
          <article class="sal-card-dark flex h-full flex-col px-6 py-7 md:px-8 md:py-8">
            <p class="sal-kicker text-white/64">Selling starts</p>
            <h2 class="sal-topo-divider sal-title-section mt-3 text-white">Keep the road choice clear and easy to explain</h2>
            <p class="sal-body-copy mt-5 text-white/78">
              Listen for the ride feel the runner wants, name the best place to start, and explain the benefit in plain language.
            </p>
            <div class="sal-course-banner sal-sell-banner mt-8 min-h-[14rem] flex-1 overflow-hidden rounded-[0.5625rem]">
              <img
                src={resolveSalomonImage("/salomon/hero-road.png")}
                alt="Salomon runners moving fast on road terrain"
                class="sal-course-banner-image"
              />
            </div>
          </article>

          <article class="sal-card-dark">
            <div class={sectionPadding}>
              <p class="sal-kicker text-white/64">Tap a customer line to reveal the answer</p>
              <div class="mt-6 grid gap-4">
                {sellingRows.map((row, index) => (
                  <article class="sal-compare-reveal">
                    <input
                      id={`road-sell-${index}`}
                      class="sal-compare-toggle"
                      type="checkbox"
                    />
                    <label class="sal-compare-summary" for={`road-sell-${index}`}>
                      <div>
                        <p class="text-[18px] font-semibold leading-8 tracking-[-0.02em] text-white">{row.prompt}</p>
                      </div>
                      <span class="sal-compare-summary__cta">Reveal answer</span>
                    </label>

                    <div class="sal-compare-answer">
                      <div class="grid gap-4">
                        <div>
                          <p class="text-xs font-bold uppercase tracking-[0.14em] text-white/64">Start with</p>
                          <p class="mt-2 text-[18px] leading-8 text-white">{row.start}</p>
                        </div>

                        <div class="w-full">
                          <p class="text-xs font-bold uppercase tracking-[0.14em] text-white/64">Why</p>
                          <p class="mt-2 text-[18px] leading-8 text-white">{row.why}</p>
                        </div>
                      </div>
                    </div>
                  </article>
                ))}
              </div>
            </div>
          </article>
        </section>

        <section class="sal-section mt-6">
          <div class={sectionPadding}>
            <p class="sal-kicker text-[#6a6257]">Team activity</p>
            <h2 class="sal-topo-divider sal-title-section mt-3 text-[var(--sal-ink)]">Practice the road conversation</h2>
            <p class="sal-body-copy mt-5 max-w-[40rem] text-[#45413b]">
              Use this activity to practice opening quickly, reading the runner, and guiding them toward the right road shoe.
            </p>

            <div class="mt-6 grid items-stretch gap-6 lg:grid-cols-[1.05fr_0.95fr]">
              <article class="sal-card h-full">
                <div class="grid h-full gap-4">
                  {dareSteps.map((step, index) => (
                    <article class="rounded-[0.5625rem] border border-[rgba(12,12,12,0.08)] bg-white/88 p-5">
                      <div class="flex items-center gap-4">
                        <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-[var(--sal-cinder)] text-[18px] font-black uppercase tracking-[0.12em] text-[var(--sal-lime)]">
                          0{index + 1}
                        </span>
                        <p class="text-[18px] leading-8 text-[#45413b]">{step}</p>
                      </div>
                    </article>
                  ))}
                </div>
              </article>

              <article class="flex h-full flex-col rounded-[0.5625rem] border border-[rgba(12,12,12,0.08)] bg-[#f3f1ed] px-6 py-7 md:px-8 md:py-8">
                <div class="flex h-full flex-col">
                  <p class="sal-kicker text-[#6a6257]">Try these opening lines</p>
                  <div class="mt-4 flex flex-1 flex-col gap-3">
                    {conversationOpeners.map((line) => (
                      <article class="flex flex-1 items-center rounded-[0.5625rem] border border-[rgba(12,12,12,0.08)] bg-white p-5">
                        <p class="sal-body-copy text-[#45413b]">{line}</p>
                      </article>
                    ))}
                  </div>
                </div>
              </article>
            </div>
          </div>
        </section>
      </div>
    </main>
    <script>
      const mobileNavs = document.querySelectorAll("[data-mobile-nav]");

      document.addEventListener("click", (event) => {
        mobileNavs.forEach((menu) => {
          if (!menu.contains(event.target)) {
            menu.removeAttribute("open");
          }
        });
      });

      mobileNavs.forEach((menu) => {
        menu.querySelectorAll("[data-mobile-nav-link]").forEach((link) => {
          link.addEventListener("click", () => {
            menu.removeAttribute("open");
          });
        });
      });

    </script>
  </body>
</html>
