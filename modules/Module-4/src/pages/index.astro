---
import "../styles/global.css";

const salomonImages = import.meta.glob("../images/salomon/**/*.{png,jpg,jpeg,avif,svg}", {
  eager: true,
  query: "?url",
  import: "default",
});

const resolveSalomonImage = (path) =>
  path.startsWith("/salomon/")
    ? salomonImages[`../images/salomon/${path.slice("/salomon/".length)}`] ?? path
    : path;

const navItems = [
  { href: "#feel", label: "Comfort or speed" },
  { href: "#core", label: "Core shoes" },
  { href: "#more-shoes", label: "More shoes" },
  { href: "#sell", label: "Sell it" },
];

const roadGroups = [
  {
    title: "Dynamic comfort",
    models: "Aero Glide 4, Aero Blaze 3",
    detail: "For long-distance runners and everyday runners seeking cushioning, smooth transitions, and dynamic comfort.",
    bestFor: ["Easy to moderate pace", "Smooth running feel", "Cushion and bounce"],
    tone: "rgba(247,246,243,0.96)",
  },
  {
    title: "Dynamic speed",
    models: "S/LAB Phantasm 3",
    detail: "For fast-paced runners chasing performance, energy return, and a lighter, more propulsive road feeling.",
    bestFor: ["Running fast", "Propulsion", "Performance training and competition"],
    tone: "rgba(242,241,238,0.96)",
  },
];

const coreProducts = [
  {
    title: "Aero Glide 4",
    image: "/salomon/aero-glide-4.png",
    group: "Dynamic comfort",
    strap: "The iconic premium comfort road model",
    metrics: ["Long-distance comfort", "Premium cushioning", "Cushion and bounce", "Everyday road use"],
    detail:
      "Aero Glide 4 is the premium comfort answer for long-distance runners and everyday runners who want cushioning and smooth, easy miles.",
    say: "Use Aero Glide 4 for runners who want the plushest, most comfort-led road feeling in the range.",
  },
  {
    title: "Aero Blaze 3",
    image: "/salomon/aero-blaze-3.png",
    group: "Dynamic comfort",
    strap: "Made for everyone, a reliable everyday running shoe",
    metrics: ["Dynamic comfort", "Fluid transitions", "High comfort fit", "Versatile road training"],
    detail:
      "Aero Blaze 3 is the one shoe that nails every session. It mixes cushioning, dynamic comfort, and smooth transitions in a lightweight construction with premium-feel performance.",
    tech: ["Engineered mesh upper", "optiFOAM2", "Road contaGRIP"],
    say: "Frame Aero Blaze 3 as the go-to road shoe: very good at everything, versatile, light, and dynamic.",
  },
  {
    title: "S/LAB Phantasm 3",
    image: "/salomon/slab-phantasm-3.png",
    group: "Dynamic speed",
    strap: "The road answer for maximum propulsion",
    metrics: ["Performance training", "Competition", "Lightweight propulsion", "Dynamic speed"],
    detail:
      "S/LAB Phantasm 3 is the speed answer for runners who want maximum energy return, lighter-feeling speed, and a stronger performance-training point of view.",
    say: "Lead with S/LAB Phantasm 3 when the customer wants to run fast and clearly identifies as performance-minded rather than comfort-led.",
  },
];

const moreRoadProducts = [
  {
    title: "S/LAB Phantasm 2 Made in France",
    image: "/salomon/road-phatansm2-mif.png",
    row: "S/LAB Proracing concept",
    group: "Dynamic speed",
    detail: "Part of the S/LAB Proracing concept within the road range.",
  },
  {
    title: "S/LAB Spectur",
    image: "/salomon/road-spectur.png",
    row: "S/LAB Proracing concept",
    group: "Dynamic speed",
    detail: "Another speed-led S/LAB option in the road range.",
  },
  {
    title: "Spectur 3",
    image: "/salomon/road-spectur3.png",
    row: "Performance and racing",
    group: "Dynamic speed",
    detail: "A performance and racing option for runners looking for a faster road shoe.",
  },
  {
    title: "INDEX.03",
    image: "/salomon/road-index03.png",
    row: "Recreational multi-activity",
    group: "Dynamic comfort",
    detail: "A comfort-led option for broader recreational and multi-activity use.",
  },
];

const sellingRows = [
  {
    prompt: "I just want one great road shoe for most runs.",
    start: "Aero Blaze 3",
    why: "Aero Blaze 3 is the reliable everyday-running answer and the broadest road recommendation in the pack.",
  },
  {
    prompt: "I want the plushest, easiest comfort ride.",
    start: "Aero Glide 4",
    why: "Aero Glide 4 is the clearest answer for premium cushion and bounce.",
  },
  {
    prompt: "I care about speed, energy return, and race-day feeling.",
    start: "S/LAB Phantasm 3",
    why: "That request points directly to the speed side of the range and the S/LAB Phantasm 3 story.",
  },
];

const conversationOpeners = [
  "What kind of run are you shopping for most?",
  "Do you want the ride to feel softer and easier, or faster and more responsive?",
  "Is this mainly for everyday runs, longer comfort runs, or speed sessions?",
  "Do you want one shoe for most runs, or something more performance-led?",
];

const dareSteps = [
  "Divide the team into two groups: customers and sales associates.",
  "Form two lines facing each other.",
  "Customers each hide a random object behind their back.",
  "Sales associates have up to 10 seconds to break the ice with one sentence based on that object.",
  "Walk forward, swap roles, and repeat.",
  "Debrief what felt easy to connect, what felt difficult, and what made the customer react.",
];

const sectionPadding = "p-6 md:p-8 lg:p-10";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Module 4 | Road running</title>
  </head>
  <body class="selection:bg-[var(--sal-lime)] selection:text-black">
    <main class="sal-shell min-h-screen">
      <div class="mx-auto max-w-[1260px] px-4 pt-2 pb-4 md:px-6 md:pt-3 md:pb-6">
        <header class="sal-card sal-section sticky top-2 z-30 overflow-visible px-4 py-4 md:top-3 md:px-6" style="z-index:60; isolation:isolate;">
          <div class="flex items-center justify-between gap-4 md:hidden">
            <div class="flex min-w-0 items-center gap-3">
              <img src="/tfg-logo.svg" alt="TFG logo" class="h-10 w-10 shrink-0" />
              <p class="min-w-0 text-sm font-medium leading-5 text-[var(--sal-ink-soft)]">Module 4 | Road running</p>
            </div>

            <details class="relative z-[70] shrink-0 md:hidden" data-mobile-nav style="z-index:70;">
              <summary class="flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-full border border-[rgba(12,12,12,0.1)] bg-white text-[var(--sal-ink-soft)] transition hover:bg-[#f4efea] [&::-webkit-details-marker]:hidden">
                <span class="sr-only">Toggle lesson navigation</span>
                <span aria-hidden="true" class="flex flex-col gap-[0.28rem]">
                  <span class="block h-[2px] w-5 rounded-full bg-current"></span>
                  <span class="block h-[2px] w-5 rounded-full bg-current"></span>
                  <span class="block h-[2px] w-5 rounded-full bg-current"></span>
                </span>
              </summary>

              <div class="absolute right-0 top-[calc(100%+0.75rem)] z-[80] w-64 max-w-[calc(100vw-1.5rem)] overflow-hidden rounded-[0.9rem] border border-[rgba(12,12,12,0.08)] bg-white p-2 shadow-[0_14px_36px_rgba(56,39,27,0.09)]" style="z-index:80;">
                <div class="flex flex-col gap-1.5 text-sm text-[var(--sal-ink-soft)]">
                  {navItems.map((item) => (
                    <a href={item.href} class="rounded-[0.75rem] px-4 py-3 transition hover:bg-[#f4efea]" data-mobile-nav-link>{item.label}</a>
                  ))}
                </div>
              </div>
            </details>
          </div>

          <div class="hidden md:flex md:items-center md:justify-between md:gap-6">
            <div class="flex min-w-0 items-center gap-4">
              <img src="/tfg-logo.svg" alt="TFG logo" class="h-11 w-11 shrink-0" />
              <div class="min-w-0">
                <p class="text-lg font-semibold tracking-[-0.03em] text-[var(--sal-ink-soft)]">Module 4 | Road running</p>
              </div>
            </div>

            <nav class="flex gap-2 overflow-x-auto pb-1 text-[0.78rem] font-bold uppercase tracking-[0.12em] text-[var(--sal-ink-soft)]">
              {navItems.map((item) => (
                <a href={item.href} class="sal-chip whitespace-nowrap hover:border-[rgba(12,12,12,0.22)] hover:bg-white">{item.label}</a>
              ))}
            </nav>
          </div>
        </header>

        <section class="sal-card-dark sal-section mt-5 overflow-hidden px-6 py-8 md:mt-6 md:px-10 md:py-12">
          <div class="grid gap-8 lg:grid-cols-[1.08fr_0.92fr] lg:items-end">
            <div>
              <p class="sal-kicker text-[var(--sal-glacier)]">Road running</p>
              <h1 class="mt-4 max-w-[13ch] text-[2.95rem] font-black uppercase leading-[0.92] tracking-[-0.07em] text-white md:text-[4.95rem]">
                Start road conversations with feel
              </h1>
              <p class="mt-5 max-w-[46rem] text-[1.08rem] leading-8 text-white/78 md:text-[1.18rem]">
                Most road runners are looking for one of two things: smoother comfort or faster response. Start there, then guide them to the right shoe.
              </p>

            </div>

            <div class="sal-hero-photo">
              <img src={resolveSalomonImage("/salomon/hero-road.png")} alt="Close-up of Salomon road running shoes in an urban setting" />
            </div>
          </div>
        </section>

        <section id="feel" class="sal-card sal-section mt-6">
          <div class={sectionPadding}>
            <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
              <div>
                <p class="sal-kicker text-[#6a6257]">Start here</p>
                <h2 class="mt-3 text-[2.15rem] font-black uppercase leading-[0.96] tracking-[-0.06em] text-[var(--sal-ink)] md:text-[3rem]">
                  Most road runners want comfort or speed
                </h2>
              </div>
            </div>

            <div class="mt-8 grid gap-4 md:grid-cols-2">
              {roadGroups.map((group) => (
                <article class="rounded-[0.5625rem] border border-[rgba(12,12,12,0.08)] p-5" style={`background:${group.tone};`}>
                  <h3 class="text-[1.45rem] font-black uppercase tracking-[-0.05em] text-[var(--sal-ink)]">{group.title}</h3>
                  <p class="mt-3 text-sm font-semibold uppercase tracking-[0.12em] text-[#5d584f]">{group.models}</p>
                  <p class="mt-4 text-sm leading-7 text-[#444039]">{group.detail}</p>
                  <ul class="mt-4 space-y-2 text-sm leading-7 text-[#403b34]">
                    {group.bestFor.map((item) => (
                      <li class="flex gap-2"><span class="mt-[0.58rem] h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--sal-ink)]"></span><span>{item}</span></li>
                    ))}
                  </ul>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section id="core" class="sal-card sal-section mt-6">
          <div class={sectionPadding}>
            <p class="sal-kicker text-[#6a6257]">Core road products</p>
            <h2 class="mt-3 text-[2.15rem] font-black uppercase leading-[0.96] tracking-[-0.06em] text-[var(--sal-ink)] md:text-[3rem]">
              Three shoes to know first
            </h2>

            <div class="mt-8 grid gap-4 md:grid-cols-3">
              {coreProducts.map((product) => (
                <article class="rounded-[0.5625rem] border border-[rgba(12,12,12,0.08)] bg-white/88 p-5">
                  <div class="sal-product-stage mb-5">
                    <img
                      src={resolveSalomonImage(product.image)}
                      alt={`${product.title} product visual`}
                    />
                  </div>

                  <p class="sal-kicker text-[#6a6257]">{product.group}</p>
                  <h3 class="mt-2 text-[1.32rem] font-semibold tracking-[-0.04em] text-[var(--sal-ink)]">{product.title}</h3>
                  <p class="mt-2 text-sm font-semibold uppercase tracking-[0.12em] text-[#5d584f]">{product.strap}</p>

                  <div class="mt-4 flex flex-wrap gap-2">
                    {product.metrics.map((metric) => (
                      <span class="rounded-[0.5625rem] border border-[rgba(12,12,12,0.08)] bg-[#f0efeb] px-3 py-2 text-xs font-bold uppercase tracking-[0.12em] text-[#5e574d]">
                        {metric}
                      </span>
                    ))}
                  </div>

                  <p class="mt-4 text-sm leading-7 text-[#45413b]">{product.detail}</p>

                  {product.tech && (
                    <div class="mt-5 rounded-[0.5625rem] bg-[#f0efeb] p-4">
                      <p class="text-xs font-bold uppercase tracking-[0.14em] text-[#71695d]">Technologies and highlights</p>
                      <ul class="mt-3 space-y-2 text-sm leading-7 text-[#403b34]">
                        {product.tech.map((item) => (
                          <li class="flex gap-2"><span class="mt-[0.58rem] h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--sal-pink)]"></span><span>{item}</span></li>
                        ))}
                      </ul>
                    </div>
                  )}

                  <div class="mt-5 rounded-[0.5625rem] border border-[rgba(12,12,12,0.08)] bg-[#151515] p-4 text-white">
                    <p class="text-xs font-bold uppercase tracking-[0.14em] text-white/56">What to say</p>
                    <p class="mt-2 text-sm leading-7 text-white/82">{product.say}</p>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section id="more-shoes" class="sal-card sal-section mt-6">
          <div class={sectionPadding}>
            <p class="sal-kicker text-[#6a6257]">More road shoes</p>
            <h2 class="mt-3 text-[2.15rem] font-black uppercase leading-[0.96] tracking-[-0.06em] text-[var(--sal-ink)] md:text-[3rem]">
              Other road shoes to know
            </h2>

            <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
              {moreRoadProducts.map((product) => (
                <article class="rounded-[0.5625rem] border border-[rgba(12,12,12,0.08)] bg-white/88 p-5">
                  <div class="sal-product-stage mb-5 p-4">
                    <img src={resolveSalomonImage(product.image)} alt={`${product.title} product visual`} class="max-h-[13.5rem] max-w-[92%]" />
                  </div>
                  <p class="sal-kicker text-[#6a6257]">{product.group}</p>
                  <h3 class="mt-2 text-[1.18rem] font-semibold tracking-[-0.03em] text-[var(--sal-ink)]">{product.title}</h3>
                  <p class="mt-2 text-xs font-bold uppercase tracking-[0.14em] text-[#71695d]">{product.row}</p>
                  <p class="mt-4 text-sm leading-7 text-[#47433d]">{product.detail}</p>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section id="sell" class="sal-section mt-6 grid gap-6 lg:grid-cols-[0.88fr_1.12fr]">
          <article class="sal-card-dark px-6 py-7 md:px-8 md:py-8">
            <p class="sal-kicker text-[var(--sal-glacier)]">Selling starts</p>
            <h2 class="mt-4 text-[2.1rem] font-black uppercase leading-[0.94] tracking-[-0.06em] text-white md:text-[3rem]">Keep the road choice clear and easy to explain</h2>
            <p class="mt-5 text-[1.02rem] leading-8 text-white/78">
              Listen for the ride feel the runner wants, name the best place to start, and explain the benefit in plain language.
            </p>
            <div class="mt-8 overflow-hidden rounded-[0.5625rem]">
              <img
                src={resolveSalomonImage("/salomon/hero-road.png")}
                alt="Salomon runners moving fast on road terrain"
                class="h-[13.5rem] w-full object-cover md:h-[16rem]"
              />
            </div>
          </article>

          <article class="sal-card">
            <div class={sectionPadding}>
              <p class="text-xs font-bold uppercase tracking-[0.14em] text-[#736d61]">Tap a customer line to reveal the answer</p>
              <div class="mt-4 grid gap-4">
                {sellingRows.map((row) => (
                  <details class="sal-compare-reveal" name="road-sell">
                    <summary class="sal-compare-summary">
                      <div>
                        <p class="text-[1.02rem] font-semibold leading-7 tracking-[-0.02em] text-[var(--sal-ink)]">{row.prompt}</p>
                      </div>
                      <span class="sal-compare-summary__cta">Reveal answer</span>
                    </summary>

                    <div class="sal-compare-answer">
                      <div class="grid gap-4 lg:grid-cols-[0.72fr_1.18fr]">
                        <div>
                          <p class="text-xs font-bold uppercase tracking-[0.14em] text-[#736d61]">Start with</p>
                          <p class="mt-2 text-sm leading-7 text-[#44403a]">{row.start}</p>
                        </div>
                        <div>
                          <p class="text-xs font-bold uppercase tracking-[0.14em] text-[#736d61]">Why</p>
                          <p class="mt-2 text-sm leading-7 text-[#44403a]">{row.why}</p>
                        </div>
                      </div>
                    </div>
                  </details>
                ))}
              </div>
            </div>
          </article>
        </section>

        <section class="sal-section mt-6 grid gap-6 lg:grid-cols-[1.05fr_0.95fr]">
            <article class="sal-card">
              <div class={sectionPadding}>
                <h2 class="text-[2.15rem] font-black uppercase tracking-[-0.05em] text-[var(--sal-ink)] md:text-[3rem]">Team activity</h2>
                <p class="mt-4 max-w-[40rem] text-[1rem] leading-8 text-[#45413b]">
                  Use this activity to practice opening quickly, reading the runner, and guiding them toward the right road shoe.
                </p>

                <div class="mt-6 grid gap-4">
                  {dareSteps.map((step, index) => (
                    <article class="rounded-[0.5625rem] border border-[rgba(12,12,12,0.08)] bg-white/88 p-5">
                      <div class="flex gap-4">
                        <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-[var(--sal-cinder)] text-sm font-black uppercase tracking-[0.12em] text-[var(--sal-lime)]">
                          0{index + 1}
                        </span>
                        <p class="text-sm leading-7 text-[#45413b]">{step}</p>
                      </div>
                    </article>
                  ))}
                </div>
              </div>
            </article>

            <article class="sal-card-dark relative overflow-hidden px-6 py-7 md:px-8 md:py-8">
              <img
                src={resolveSalomonImage("/salomon/store-image.jpg")}
                alt="Salomon store environment"
                class="absolute inset-0 h-full w-full object-cover"
              />
              <div class="absolute inset-0 bg-[linear-gradient(120deg,rgba(10,10,10,0.72)_0%,rgba(10,10,10,0.5)_42%,rgba(10,10,10,0.64)_100%)]"></div>
              <div class="relative">
                <p class="text-xs font-bold uppercase tracking-[0.14em] text-white/64">Try these opening lines</p>
                <div class="mt-4 grid gap-3">
                  {conversationOpeners.map((line) => (
                    <article class="rounded-[0.5625rem] border border-white/10 bg-black/28 p-5 backdrop-blur-[2px]">
                      <p class="text-[1rem] leading-8 text-white/92 md:text-[1.05rem]">{line}</p>
                    </article>
                  ))}
                </div>
              </div>
            </article>
        </section>
      </div>
    </main>
    <script>
      const mobileNavs = document.querySelectorAll("[data-mobile-nav]");

      document.addEventListener("click", (event) => {
        mobileNavs.forEach((menu) => {
          if (!menu.contains(event.target)) {
            menu.removeAttribute("open");
          }
        });
      });

      mobileNavs.forEach((menu) => {
        menu.querySelectorAll("[data-mobile-nav-link]").forEach((link) => {
          link.addEventListener("click", () => {
            menu.removeAttribute("open");
          });
        });
      });
    </script>
  </body>
</html>
